# Used when running `npm run dev` or `npm run build` from ./frontend (not inside Docker).
# Copy to .env.local (recommended) or .env — Next.js loads these automatically.

NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

# If FastAPI runs locally on port 8000:
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
