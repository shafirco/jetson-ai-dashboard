# Copy to ".env" in this folder (optional). Docker Compose reads .env automatically.
# Default below matches docker-compose fallbacks (backend service name + internal port).

NEXT_PUBLIC_BACKEND_URL=http://backend:8000

# Local development (Next on host, FastAPI on host or published Docker port):
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8001
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
